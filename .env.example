# Copia questo file in .env e modifica i valori se necessario.
# Con docker-compose i default vanno già bene così.

# Porta del bridge server (default: 3000)
# PORT=3000

# URL ChromaDB — dentro docker usa il service name, fuori docker usa localhost
# CHROMA_URL=http://localhost:8000

# URL Ollama — dentro docker usa il service name, fuori docker usa localhost
# OLLAMA_BASE=http://localhost:11434

# Modello embedding (default: nomic-embed-text)
# EMBED_MODEL=nomic-embed-text

# Cartella host montata in /workspace dentro il container per /api/ingest-codebase.
# Default: la directory dove sta docker-compose.yml.
# Esempio per ingestare progetti sotto C:\daniel: CODEBASE_HOST_PATH=C:\daniel
# CODEBASE_HOST_PATH=.
